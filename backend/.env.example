DATABASE_URL=postgres://nous:change-me@localhost:5434/nous
PORT=3002

# Recomendado para uso personal: modelo local vía Ollama (https://ollama.com), sin
# coste ni clave de API — instala Ollama, `ollama pull mxbai-embed-large` y
# `ollama pull qwen2.5:7b-instruct`, y descomenta la línea de abajo.
# OLLAMA_BASE_URL=http://localhost:11434

# Opcionales, mejor calidad pero de pago: API de Claude/Voyage. Si se ponen, tienen
# prioridad sobre Ollama. Sin nada de esto configurado, la app arranca igual con
# proveedores simulados (respuestas genéricas, embeddings deterministas).
ANTHROPIC_API_KEY=
VOYAGE_API_KEY=

# Opcional: si la pones, la API exige "Authorization: Bearer <valor>" en todas las
# rutas salvo /health. Déjala sin poner para el uso personal habitual por Tailscale
# (sin fricción); actívala solo si vas a exponer la API más allá de tu red privada.
# El frontend necesita el mismo valor en VITE_API_TOKEN (ver .env.example de la raíz).
API_TOKEN=

# Base de datos separada para los tests de integración (nunca la real): créala con
# `createdb` o `psql -c "CREATE DATABASE nous_test"` (con la extensión vector
# disponible) y aplícale las migraciones con TEST_DATABASE_URL=... npm run migrate:up.
TEST_DATABASE_URL=postgres://nous:change-me@localhost:5434/nous_test
